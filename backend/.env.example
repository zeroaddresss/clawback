# Optional for read-only mode, required for write operations + event streaming
# If missing, GET endpoints still work but POST endpoints will return an error.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Required: RPC endpoint URL
RPC_URL=https://sepolia.base.org

# Required: USDC token contract address
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Required: Deployed USDCEscrow contract address
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Optional: Server port (default: 3001)
PORT=3001

# Optional: Internal API bind port behind the edge router (default: 3002)
API_PORT=3002

# Optional: Network name returned in /health (default: base-sepolia)
NETWORK_NAME=base-sepolia

# Optional: Public wallet shown by /health when signer key is not configured
WALLET_ADDRESS=0x85d35Dd5e2cAB1fbf3543EE088eFA151EEe525C8

# Optional: CORS allowed origin (default: * — restrict in production)
CORS_ORIGIN=*
